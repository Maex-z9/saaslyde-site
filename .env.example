# Marketing site env. None are required to build, but missing values gracefully
# disable the corresponding feature.

# Public canonical URL. Used for OG metadata + sitemap.xml + robots.txt.
# NEXT_PUBLIC_SITE_URL=https://saaslyde.com

# Formspree form ID for the pricing-page waitlist.
# Without this, the waitlist form is hidden and a "write us at support@…" hint shows instead.
# Get one at https://formspree.io → create form → copy the ID after /f/
# NEXT_PUBLIC_FORMSPREE_ID=
